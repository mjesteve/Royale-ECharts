      "version": "2.0.0",
      "tasks": [
        {
            "label": "Build with Maven",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "install",
                "-P option-with-swf",
                "-DskipTests"
            ],
            "problemMatcher": []
        },
        {
            "label": "Build with Maven - Droyalelib",
            "type": "shell",
            "command": "mvn",
            "args": [
                "clean",
                "install",
                "-Droyalelib=${env:ROYALE_LIB_DEBUG}",
                "-DskipTests"
            ],
            "problemMatcher": [],
            "group": {
                "kind": "build",
                "isDefault": true
            }
        }
    ]
  }